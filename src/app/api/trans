import { query, generateId } from "@/lib/db";

export async function GET(request: Request) {
  try {
    const { searchParams } = new URL(request.url);
    const periode = searchParams.get("periode") || "all";

    let sql =
      "SELECT * FROM transaksi WHERE deleted_at IS NULL ORDER BY tanggal DESC";
    const params: any[] = [];

    if (periode !== "all") {
      const now = new Date();
      let startDate: Date;
      if (periode === "harian") {
        startDate = new Date(now.getFullYear(), now.getMonth(), now.getDate());
      } else if (periode === "mingguan") {
        startDate = new Date(now.getTime() - 7 * 86400000);
      } else {
        startDate = new Date(now.getTime() - 30 * 86400000);
      }
      sql =
        "SELECT * FROM transaksi WHERE tanggal >= ? AND deleted_at IS NULL ORDER BY tanggal DESC";
      params.push(startDate.toISOString().slice(0, 19).replace("T", " "));
    }

    const transaksi: any = await query(sql, params);

    // Get details for each transaction
    for (let t of transaksi) {
      const details: any = await query(
        "SELECT * FROM detail_transaksi WHERE transaksi_id = ?",
        [t.id],
      );
      t.items = details;
    }

    return Response.json(transaksi);
  } catch (error) {
    return Response.json(
      { error: "Failed to fetch transaksi" },
      { status: 500 },
    );
  }
}

export async function POST(request: Request) {
  try {
    const data = await request.json();
    const id = await generateId();

    await query(
      "INSERT INTO transaksi (id, tanggal, total, diskon, pajak, metode_bayar, user_id) VALUES (?, ?, ?, ?, ?, ?, ?)",
      [
        id,
        data.tanggal,
        data.total,
        data.diskon || 0,
        data.pajak || 0,
        data.metode_bayar,
        data.user_id,
      ],
    );

    // Insert details (stok & log dihapus karena user tidak pakai stok)
    for (const item of data.items) {
      const detailId = await generateId();
      await query(
        "INSERT INTO detail_transaksi (id, transaksi_id, menu_id, nama_menu, qty, harga, subtotal) VALUES (?, ?, ?, ?, ?, ?, ?)",
        [
          detailId,
          id,
          item.menu_id,
          item.nama_menu,
          item.qty,
          item.harga,
          item.subtotal,
        ],
      );
    }

    return Response.json({ success: true, id });
  } catch (error) {
    console.error("Transaksi error:", error);
    return Response.json(
      { error: "Failed to save transaksi" },
      { status: 500 },
    );
  }
}
